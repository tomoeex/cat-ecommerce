<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Error' %> - Cat Supplies Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .error-icon {
            animation: shake 0.5s;
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-lg">
                    <div class="card-body text-center py-5">
                        <div class="error-icon mb-4">
                            <i class="fas fa-exclamation-triangle fa-5x text-danger"></i>
                        </div>
                        
                        <h1 class="display-4 text-danger mb-3">
                            <%= title || 'Oops! Something went wrong' %>
                        </h1>
                        
                        <p class="lead text-muted mb-4">
                            <%= error.message || 'An unexpected error occurred. Please try again later.' %>
                        </p>

                        <% if(error.stack && typeof process !== 'undefined' && process.env && process.env.NODE_ENV === 'development') { %>
                        <div class="alert alert-warning text-start mb-4">
                            <h6>Error Details (Development Mode):</h6>
                            <pre class="small mb-0"><%= error.stack %></pre>
                        </div>
                        <% } %>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Go Back
                            </a>
                            <a href="/" class="btn btn-primary btn-lg">
                                <i class="fas fa-home"></i> Go to Homepage
                            </a>
                        </div>

                        <hr class="my-4">

                        <div class="text-muted">
                            <p class="mb-2">
                                <i class="fas fa-question-circle"></i> Need help?
                            </p>
                            <p>
                                <a href="/contact" class="text-decoration-none">Contact our support team</a>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="card mt-3 bg-dark text-white">
                    <div class="card-body">
                        <h6 class="mb-3">Quick Links</h6>
                        <div class="row">
                            <div class="col-md-3">
                                <a href="/" class="text-white text-decoration-none">
                                    <i class="fas fa-home"></i> Home
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/products" class="text-white text-decoration-none">
                                    <i class="fas fa-shopping-bag"></i> Products
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/contact" class="text-white text-decoration-none">
                                    <i class="fas fa-envelope"></i> Contact
                                </a>
                            </div>
                            <div class="col-md-3">
                                <a href="/auth/login" class="text-white text-decoration-none">
                                    <i class="fas fa-sign-in-alt"></i> Login
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>