<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
        }
        .cat-404 {
            font-size: 120px;
            animation: bounce 2s infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        .paw-print {
            animation: fadeIn 1s ease-in-out infinite alternate;
        }
        @keyframes fadeIn {
            from { opacity: 0.3; }
            to { opacity: 1; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-lg">
                    <div class="card-body text-center py-5">
                        <!-- Cat 404 Icon -->
                        <div class="cat-404 mb-4">
                            <i class="fas fa-cat text-primary"></i>
                        </div>
                        
                        <h1 class="display-1 fw-bold text-primary mb-3">404</h1>
                        <h2 class="mb-3">Meow! Page Not Found</h2>
                        
                        <p class="lead text-muted mb-4">
                            The page you're looking for seems to have wandered off like a curious cat...
                        </p>

                        <!-- Paw Prints -->
                        <div class="mb-4">
                            <i class="fas fa-paw text-muted paw-print me-2"></i>
                            <i class="fas fa-paw text-muted paw-print me-2"></i>
                            <i class="fas fa-paw text-muted paw-print me-2"></i>
                            <i class="fas fa-paw text-muted paw-print"></i>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mb-4">
                            <a href="/" class="btn btn-primary btn-lg">
                                <i class="fas fa-home"></i> Go to Homepage
                            </a>
                            <a href="/products" class="btn btn-outline-primary btn-lg">
                                <i class="fas fa-shopping-bag"></i> Browse Products
                            </a>
                        </div>

                        <div class="text-muted">
                            <p class="small">
                                <i class="fas fa-lightbulb"></i> 
                                Try searching for what you need or check our popular categories below
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Popular Categories -->
                <div class="card mt-3">
                    <div class="card-body">
                        <h5 class="mb-3">Popular Categories</h5>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <a href="/products?category=1" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-drumstick-bite"></i> Cat Food
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/products?category=2" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-football-ball"></i> Cat Toys
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/products?category=3" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-box"></i> Cat Litter
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Search Box -->
                <div class="card mt-3 bg-light">
                    <div class="card-body">
                        <h6 class="mb-3">Can't find what you're looking for?</h6>
                        <form action="/products" method="GET">
                            <div class="input-group">
                                <input type="text" class="form-control" name="search" 
                                       placeholder="Search for products...">
                                <button class="btn btn-primary" type="submit">
                                    <i class="fas fa-search"></i> Search
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Fun Fact -->
                <div class="card mt-3 bg-warning">
                    <div class="card-body text-center">
                        <small>
                            <i class="fas fa-smile"></i> 
                            <strong>Fun Fact:</strong> Cats spend 70% of their lives sleeping. 
                            Maybe our page went for a nap too! 😸
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>